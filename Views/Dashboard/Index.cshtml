@model List<LostAndFound.Models.Entities.Item>

@{
    var items = Model ?? new List<LostAndFound.Models.Entities.Item>();
    var lostCount = items.Count(i => i.Status == "Lost");
    var foundCount = items.Count(i => i.Status == "Found");
    var userName = Context.Session.GetString("UserName") ?? "there";
}

<style>
    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        font-family: 'Segoe UI', sans-serif;
        background: #F8F9FA;
        min-height: 100vh;
    }

    /* NAV */
    .lf-nav {
        background: #fff;
        border-bottom: 1px solid #EBEBEB;
        padding: 16px 40px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        position: sticky;
        top: 0;
        z-index: 10;
    }

    .lf-nav-logo {
        font-size: 1.1rem;
        font-weight: 700;
        color: #1a1a1a;
        letter-spacing: -.3px;
    }

        .lf-nav-logo span {
            color: #C2185B;
        }

    .lf-nav-right {
        display: flex;
        align-items: center;
        gap: 20px;
    }

    .lf-nav-user {
        font-size: .85rem;
        color: #888;
    }

        .lf-nav-user strong {
            color: #333;
            font-weight: 600;
        }

    .lf-logout {
        font-size: .82rem;
        padding: 7px 18px;
        border-radius: 8px;
        border: 1px solid #E0E0E0;
        color: #555;
        text-decoration: none;
        font-weight: 500;
        transition: all .15s;
    }

        .lf-logout:hover {
            border-color: #C2185B;
            color: #C2185B;
        }

    /* WRAP */
    .lf-wrap {
        max-width: 1080px;
        margin: 0 auto;
        padding: 40px 24px 80px;
    }

    /* GREETING */
    .lf-greeting {
        background: #1a1a1a;
        border-radius: 16px;
        padding: 40px 44px;
        color: #fff;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
    }

        .lf-greeting h1 {
            font-size: 1.55rem;
            font-weight: 700;
            letter-spacing: -.4px;
            margin-bottom: 6px;
            color: #fff;
        }

            .lf-greeting h1 span {
                color: #E91E8C;
            }

        .lf-greeting p {
            font-size: .9rem;
            color: #999;
        }

    .lf-post-btn {
        background: #fff;
        color: #1a1a1a;
        font-weight: 600;
        font-size: .875rem;
        padding: 11px 22px;
        border-radius: 10px;
        text-decoration: none;
        white-space: nowrap;
        flex-shrink: 0;
        border: none;
        transition: background .15s, color .15s;
    }

        .lf-post-btn:hover {
            background: #E91E8C;
            color: #fff;
        }

    /* STATS */
    .lf-stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 14px;
        margin-bottom: 36px;
    }

    .lf-stat {
        background: #fff;
        border-radius: 12px;
        padding: 20px 22px;
        border: 1px solid #EBEBEB;
        display: flex;
        align-items: center;
        gap: 14px;
        transition: border-color .2s;
    }

        .lf-stat:hover {
            border-color: #C2185B;
        }

    .lf-stat-icon {
        width: 42px;
        height: 42px;
        border-radius: 10px;
        display: grid;
        place-items: center;
        font-size: 1.2rem;
        flex-shrink: 0;
        background: #F8F9FA;
    }

    .lf-stat-num {
        font-size: 1.7rem;
        font-weight: 800;
        color: #1a1a1a;
        line-height: 1;
    }

    .lf-stat-label {
        font-size: .72rem;
        color: #AAA;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .06em;
        margin-top: 4px;
    }

    /* SECTION HEADER */
    .lf-section-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 16px;
    }

    .lf-section-title {
        font-size: 1rem;
        font-weight: 700;
        color: #1a1a1a;
    }

    .lf-filters {
        display: flex;
        gap: 6px;
    }

    .lf-filter {
        padding: 5px 14px;
        border-radius: 6px;
        font-size: .78rem;
        font-weight: 600;
        border: 1px solid #E0E0E0;
        background: #fff;
        color: #888;
        cursor: pointer;
        transition: all .15s;
        text-decoration: none;
    }

        .lf-filter.active, .lf-filter:hover {
            background: #1a1a1a;
            color: #fff;
            border-color: #1a1a1a;
        }

    /* GRID */
    .lf-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 14px;
    }

    .lf-card {
        background: #fff;
        border-radius: 12px;
        padding: 20px;
        border: 1px solid #EBEBEB;
        transition: border-color .2s, box-shadow .2s;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

        .lf-card:hover {
            border-color: #ddd;
            box-shadow: 0 4px 18px rgba(0,0,0,.07);
        }

    .lf-card-top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 10px;
    }

    .lf-card-title {
        font-size: .95rem;
        font-weight: 700;
        color: #1a1a1a;
        line-height: 1.3;
    }

    .lf-tag {
        font-size: .65rem;
        font-weight: 700;
        padding: 3px 9px;
        border-radius: 5px;
        white-space: nowrap;
        flex-shrink: 0;
        letter-spacing: .05em;
        text-transform: uppercase;
    }

    .lf-tag-lost {
        background: #FFF0F0;
        color: #C62828;
        border: 1px solid #FFCDD2;
    }

    .lf-tag-found {
        background: #F0FFF8;
        color: #2E7D32;
        border: 1px solid #C8F7DC;
    }

    .lf-desc {
        font-size: .85rem;
        color: #777;
        line-height: 1.65;
        flex: 1;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .lf-meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-top: 10px;
        border-top: 1px solid #F0F0F0;
    }

    .lf-meta-cat {
        font-size: .72rem;
        color: #AAA;
        font-weight: 500;
    }

    .lf-view {
        font-size: .8rem;
        font-weight: 600;
        color: #C2185B;
        text-decoration: none;
        transition: letter-spacing .15s;
    }

        .lf-view:hover {
            letter-spacing: .02em;
        }

    /* EMPTY */
    .lf-empty {
        grid-column: 1 / -1;
        text-align: center;
        padding: 80px 24px;
        color: #bbb;
    }

    .lf-empty-icon {
        font-size: 3rem;
        margin-bottom: 14px;
        display: block;
    }

    .lf-empty-title {
        font-size: 1rem;
        font-weight: 700;
        color: #999;
        margin-bottom: 6px;
    }

    .lf-empty-sub {
        font-size: .85rem;
        color: #bbb;
        margin-bottom: 22px;
    }

    .lf-empty-btn {
        display: inline-block;
        background: #1a1a1a;
        color: #fff;
        padding: 11px 26px;
        border-radius: 10px;
        font-weight: 600;
        text-decoration: none;
        font-size: .875rem;
        transition: background .15s;
    }

        .lf-empty-btn:hover {
            background: #C2185B;
        }
</style>

<!-- Nav -->
<nav class="lf-nav">
    <div class="lf-nav-logo">Lost<span>&</span>Found</div>
    <div class="lf-nav-right">
        <span class="lf-nav-user">Hello, <strong>@userName</strong></span>
        <a href="/Account/Logout" class="lf-logout">Sign out</a>
    </div>
</nav>

<div class="lf-wrap">

    <!-- Greeting -->
    <div class="lf-greeting">
        <div>
            <h1>Good to see you, <span>@userName</span></h1>
            <p>Here's what's been reported so far.</p>
        </div>
        <a class="lf-post-btn" asp-controller="Items" asp-action="Add">+ Post an item</a>
    </div>

    <!-- Stats -->
    <div class="lf-stats">
        <div class="lf-stat">
            <div class="lf-stat-icon">📋</div>
            <div>
                <div class="lf-stat-num">@items.Count</div>
                <div class="lf-stat-label">Total Items</div>
            </div>
        </div>
        <div class="lf-stat">
            <div class="lf-stat-icon">🔎</div>
            <div>
                <div class="lf-stat-num">@lostCount</div>
                <div class="lf-stat-label">Lost Items</div>
            </div>
        </div>
        <div class="lf-stat">
            <div class="lf-stat-icon">✅</div>
            <div>
                <div class="lf-stat-num">@foundCount</div>
                <div class="lf-stat-label">Found Items</div>
            </div>
        </div>
    </div>

    <!-- Section Header -->
    <div class="lf-section-header">
        <div class="lf-section-title">All Items</div>
        <div class="lf-filters">
            <a class="lf-filter active" href="#">All</a>
            <a class="lf-filter" href="#">Lost</a>
            <a class="lf-filter" href="#">Found</a>
        </div>
    </div>

    <!-- Cards -->
    <div class="lf-grid">
        @if (!items.Any())
        {
            <div class="lf-empty">
                <span class="lf-empty-icon">🔍</span>
                <div class="lf-empty-title">Nothing here yet</div>
                <p class="lf-empty-sub">Be the first to post a lost or found item.</p>
                <a class="lf-empty-btn" asp-controller="Items" asp-action="Add">+ Post an item</a>
            </div>
        }
        else
        {
            @foreach (var item in items)
            {
                var tagClass = item.Status == "Lost" ? "lf-tag-lost" : "lf-tag-found";

                <div class="lf-card">
                    <div class="lf-card-top">
                        <p class="lf-card-title">@item.Title</p>
                        <span class="lf-tag @tagClass">@item.Status</span>
                    </div>
                    <p class="lf-desc">@item.Description</p>
                    <div class="lf-meta">
                        <span class="lf-meta-cat">@(item.Category?.Name ?? "Uncategorized")</span>
                        <a class="lf-view" asp-controller="Items" asp-action="Details" asp-route-id="@item.Id">View →</a>
                    </div>
                </div>
            }
        }
    </div>
</div>
