@model LostAndFound.Models.Entities.Item

@{
    var userName = Context.Session.GetString("UserName") ?? "there";
    var isLost = Model.Status == "Lost";
    var tagClass = isLost ? "tag-lost" : "tag-found";
}

<style>
    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        font-family: 'Segoe UI', sans-serif;
        background: #F8F9FA;
        min-height: 100vh;
    }

    .lf-nav {
        background: #fff;
        border-bottom: 1px solid #EBEBEB;
        padding: 16px 40px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        position: sticky;
        top: 0;
        z-index: 10;
    }

    .lf-nav-logo {
        font-size: 1.1rem;
        font-weight: 700;
        color: #1a1a1a;
    }

        .lf-nav-logo span {
            color: #C2185B;
        }

    .lf-nav-right {
        display: flex;
        align-items: center;
        gap: 20px;
    }

    .lf-nav-user {
        font-size: .85rem;
        color: #888;
    }

        .lf-nav-user strong {
            color: #333;
            font-weight: 600;
        }

    .lf-logout {
        font-size: .82rem;
        padding: 7px 18px;
        border-radius: 8px;
        border: 1px solid #E0E0E0;
        color: #555;
        text-decoration: none;
        font-weight: 500;
        transition: all .15s;
    }

        .lf-logout:hover {
            border-color: #C2185B;
            color: #C2185B;
        }

    .lf-wrap {
        max-width: 800px;
        margin: 0 auto;
        padding: 40px 24px 80px;
    }

    .lf-back {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: .85rem;
        font-weight: 600;
        color: #888;
        text-decoration: none;
        margin-bottom: 24px;
        transition: color .15s;
    }

        .lf-back:hover {
            color: #C2185B;
        }

    .lf-card {
        background: #fff;
        border-radius: 16px;
        border: 1px solid #EBEBEB;
        overflow: hidden;
    }

    .lf-card-header {
        background: #1a1a1a;
        padding: 32px 36px;
        color: #fff;
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 16px;
    }

        .lf-card-header h1 {
            font-size: 1.5rem;
            font-weight: 700;
            letter-spacing: -.3px;
            margin-bottom: 8px;
            color: #fff;
        }

    .lf-reported {
        font-size: .8rem;
        color: #777;
    }

    .lf-tag {
        font-size: .65rem;
        font-weight: 700;
        padding: 5px 12px;
        border-radius: 6px;
        text-transform: uppercase;
        letter-spacing: .06em;
        flex-shrink: 0;
        margin-top: 4px;
    }

    .tag-lost {
        background: #FFF0F0;
        color: #C62828;
        border: 1px solid #FFCDD2;
    }

    .tag-found {
        background: #F0FFF8;
        color: #2E7D32;
        border: 1px solid #C8F7DC;
    }

    .lf-card-body {
        padding: 32px 36px;
    }

    .lf-section-label {
        font-size: .7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .08em;
        color: #AAA;
        margin-bottom: 8px;
    }

    .lf-description {
        font-size: .95rem;
        color: #444;
        line-height: 1.75;
        margin-bottom: 28px;
        padding-bottom: 28px;
        border-bottom: 1px solid #F0F0F0;
    }

    .lf-meta-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
        margin-bottom: 28px;
        padding-bottom: 28px;
        border-bottom: 1px solid #F0F0F0;
    }

    .lf-meta-label {
        font-size: .7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .08em;
        color: #BBB;
        margin-bottom: 5px;
    }

    .lf-meta-value {
        font-size: .9rem;
        font-weight: 600;
        color: #222;
    }

        .lf-meta-value.pink {
            color: #C2185B;
        }

    .lf-reporter {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 28px;
        padding-bottom: 28px;
        border-bottom: 1px solid #F0F0F0;
    }

    .lf-avatar {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: #1a1a1a;
        color: #fff;
        font-weight: 700;
        font-size: .95rem;
        display: grid;
        place-items: center;
        flex-shrink: 0;
    }

    .lf-reporter-name {
        font-size: .9rem;
        font-weight: 600;
        color: #1a1a1a;
    }

    .lf-reporter-label {
        font-size: .75rem;
        color: #AAA;
        margin-top: 2px;
    }

    .lf-actions {
        display: flex;
        gap: 12px;
    }

    .lf-btn {
        padding: 11px 24px;
        border-radius: 10px;
        font-size: .875rem;
        font-weight: 600;
        text-decoration: none;
        cursor: pointer;
        border: none;
        transition: all .15s;
        display: inline-block;
    }

    .lf-btn-primary {
        background: #1a1a1a;
        color: #fff;
    }

        .lf-btn-primary:hover {
            background: #C2185B;
            color: #fff;
        }

    .lf-btn-ghost {
        background: transparent;
        color: #666;
        border: 1px solid #E0E0E0;
    }

        .lf-btn-ghost:hover {
            border-color: #C2185B;
            color: #C2185B;
        }

    .lf-status-banner {
        padding: 14px 18px;
        border-radius: 10px;
        font-size: .85rem;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 10px;
        margin: 24px 36px 0;
    }

        .lf-status-banner.lost {
            background: #FFF5F5;
            color: #C62828;
            border: 1px solid #FFCDD2;
        }

        .lf-status-banner.found {
            background: #F5FFF9;
            color: #2E7D32;
            border: 1px solid #C8F7DC;
        }
</style>

<nav class="lf-nav">
    <div class="lf-nav-logo">Lost<span>&</span>Found</div>
    <div class="lf-nav-right">
        <span class="lf-nav-user">Hello, <strong>@userName</strong></span>
        <a href="/Account/Logout" class="lf-logout">Sign out</a>
    </div>
</nav>

<div class="lf-wrap">
    <a class="lf-back" asp-controller="Dashboard" asp-action="Index">← Back to all items</a>

    <div class="lf-card">
        <div class="lf-card-header">
            <div>
                <h1>@Model.Title</h1>
                <span class="lf-reported">Reported on @Model.ReportedAt.ToString("MMMM dd, yyyy · hh:mm tt")</span>
            </div>
            <span class="lf-tag @tagClass">@Model.Status</span>
        </div>

        <div class="lf-status-banner @(isLost ? "lost" : "found")">
            @if (isLost)
            {
                <span>🔎 This item has been reported as <strong>lost</strong>. If you found it, please reach out to the reporter.</span>
            }
            else
            {
                <span>✅ This item has been <strong>found</strong>. If it belongs to you, please claim it.</span>
            }
        </div>

        <div class="lf-card-body">
            <div class="lf-section-label">Description</div>
            <div class="lf-description">@Model.Description</div>

            <div class="lf-meta-grid">
                <div>
                    <div class="lf-meta-label">Category</div>
                    <div class="lf-meta-value pink">@(Model.Category?.Name ?? "Uncategorized")</div>
                </div>
                <div>
                    <div class="lf-meta-label">Status</div>
                    <div class="lf-meta-value">@Model.Status</div>
                </div>
                <div>
                    <div class="lf-meta-label">Date Reported</div>
                    <div class="lf-meta-value">@Model.ReportedAt.ToString("MMM dd, yyyy")</div>
                </div>
                <div>
                    <div class="lf-meta-label">Item ID</div>
                    <div class="lf-meta-value">#@Model.Id</div>
                </div>
            </div>

            <div class="lf-section-label">Reported By</div>
            <div class="lf-reporter">
                <div class="lf-avatar">@(Model.User?.Name?.Substring(0, 1).ToUpper() ?? "?")</div>
                <div>
                    <div class="lf-reporter-name">@(Model.User?.Name ?? "Unknown")</div>
                    <div class="lf-reporter-label">@(Model.User?.Email ?? "")</div>
                </div>
            </div>

            <div class="lf-actions">
                @if (isLost)
                {
                    <a class="lf-btn lf-btn-primary" href="#">I Found This Item</a>
                }
                else
                {
                    <a class="lf-btn lf-btn-primary" href="#">This Is Mine — Claim It</a>
                }
                <a class="lf-btn lf-btn-ghost" asp-controller="Dashboard" asp-action="Index">Go Back</a>
            </div>
        </div>
    </div>
</div>
